{
  "name": "architect-guardian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "compile": "turbo run build",
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=@architect-guardian/mcp-server",
    "dev:extension": "turbo run dev --filter=@architect-guardian/vscode-extension",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "turbo run test",
    "sync-versions": "node scripts/sync-versions.js",
    "clean": "rm -rf node_modules **/node_modules **/dist **/out",
    "bootstrap": "node scripts/bootstrap.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
