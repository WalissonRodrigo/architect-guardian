{
  "name": "@architect-guardian/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "compile": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "inspector": "npx @modelcontextprotocol/inspector dist/server.js",
    "test": "vitest run",
    "setup-claude": "node dist/scripts/setup-claude.js",
    "bundle": "esbuild src/server.ts --bundle --platform=node --outfile=dist/index.cjs --format=cjs --minify --sourcemap"
  },
  "dependencies": {
    "@architect-guardian/shared-types": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@typescript-eslint/typescript-estree": "^8.56.0",
    "chokidar": "^5.0.0",
    "handlebars": "^4.7.8",
    "node-cache": "^5.1.2",
    "simple-git": "^3.32.2",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^20.0.0",
    "@types/node-cache": "^4.1.3",
    "esbuild": "^0.27.3",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
